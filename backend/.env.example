# ─── Server ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_VERSION=v1

# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/nexus_db?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Supabase (used for storage & auth bridge if needed) ─────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── Stripe ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Storage (S3-compatible) ─────────────────────────────────────────────
S3_ENDPOINT="https://s3.amazonaws.com"
S3_REGION="us-east-1"
S3_BUCKET="nexus-media"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_CDN_URL="https://cdn.nexus.app"

# ─── Email ───────────────────────────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_..."
EMAIL_FROM="noreply@nexus.app"

# ─── Push Notifications ──────────────────────────────────────────────────
FCM_SERVER_KEY="your-firebase-server-key"
APNS_KEY_ID="your-apns-key-id"
APNS_TEAM_ID="your-apple-team-id"

# ─── Frontend ────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,https://nexus.app"

# ─── Rate Limiting ───────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=debug
