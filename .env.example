# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Expo Configuration
EXPO_TOKEN=your_expo_token

# EAS Build Configuration
EAS_BUILD_USERNAME=your_expo_username
EAS_BUILD_PASSWORD=your_expo_password

# iOS Configuration (for iOS builds)
APPLE_ID=your_apple_id_email
APPLE_ID_PASSWORD=your_apple_id_password
APPLE_TEAM_ID=your_apple_team_id

# Google Play Configuration (for Android builds)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json

# Vercel Configuration (for web deployment)
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_vercel_organization_id
VERCEL_PROJECT_ID=your_vercel_project_id

# Analytics and Monitoring
SENTRY_DSN=your_sentry_dsn
GOOGLE_ANALYTICS_ID=your_google_analytics_id
FIREBASE_CONFIG=your_firebase_config

# Development
NODE_ENV=development
LOG_LEVEL=debug
