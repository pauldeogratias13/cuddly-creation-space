{
  "name": "@nexus/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo build",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "preview": "expo start --dev-client",
    "lint": "eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@nexus/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~52.0.0",
    "expo-auth-session": "~6.0.0",
    "expo-camera": "~15.0.16",
    "expo-constants": "~16.0.2",
    "expo-crypto": "~14.0.0",
    "expo-device": "~6.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.9",
    "expo-image-picker": "~15.0.7",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~6.3.1",
    "expo-local-authentication": "~14.1.1",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.23",
    "expo-secure-store": "~13.0.2",
    "expo-sharing": "~12.0.2",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~4.0.0",
    "expo-web-browser": "~14.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react-native": "^1.11.0",
    "nativewind": "^2.0.11",
    "react": "18.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.8.0",
    "sonner-native": "^0.15.6",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "@types/react-native": "~0.76.5",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.7.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.3"
  },
  "expo": {
    "name": "NEXUS",
    "slug": "nexus-super-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nexus.superapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.nexus.superapp"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NEXUS to access your camera"
        }
      ],
      [
        "expo-secure-store",
        {
          "faceId": "Allow NEXUS to use Face ID"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": {
            "color": "#ffffff"
          }
        }
      ]
    ],
    "scheme": "nexus",
    "experiments": {
      "typedRoutes": true
    }
  }
}
