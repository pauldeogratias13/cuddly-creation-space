{
  "name": "@nexus/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios --profile simulator --non-interactive",
    "build:android": "eas build --platform android --profile production --non-interactive",
    "build": "eas build --platform all --profile production --non-interactive",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
    "submit": "eas submit --platform all",
    "preview": "expo start --dev-client",
    "lint": "eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "clsx",
          "framer-motion",
          "@nexus/shared"
        ]
      }
    },
    "install": {
      "exclude": []
    }
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@expo/vector-icons": "~14.0.4",
    "@nexus/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~52.0.46",
    "expo-auth-session": "~6.0.0",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.0",
    "expo-device": "~7.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.5",
    "expo-local-authentication": "~15.0.2",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.1",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.0",
    "expo-web-browser": "~14.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react-native": "^1.11.0",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-hook-form": "^7.71.2",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "sonner-native": "^0.14.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/eas-json": "^0.3.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/react": "~18.3.12",
    "eslint": "^9.32.0",
    "eslint-config-expo": "~8.0.1",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.3"
  }
}
