  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/eas-json": "^0.3.0",
    "@types/react": "~18.3.12",
    "@types/react-native": "0.73.0",
    "eslint": "^9.32.0",
    "eslint-config-expo": "~7.1.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.3"
