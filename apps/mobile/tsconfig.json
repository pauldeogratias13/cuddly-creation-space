{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@nexus/shared": ["../../packages/shared/src"]
    },
    "allowJs": true,
    "jsx": "react-native",
    "types": [],
    "noEmit": true
  },
  "include": [
    "app/**/*",
    "*.ts",
    "*.tsx"
  ],
  "exclude": [
    "node_modules",
    "expo-module"
  ]
}
